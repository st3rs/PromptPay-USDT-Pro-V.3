# App Config
APP_NAME="PromptPay USDT Pro"
APP_URL="http://localhost:3000"
APP_DEFAULT_LOCALE="th"
APP_SUPPORTED_LOCALES="th,en"

# Auth
JWT_SECRET="super-secret-key-change-in-production"

# Database
# Local SQLite (for local dev only — NOT supported on Vercel):
#   DATABASE_URL="file:./dev.db"
#
# PostgreSQL (required for Vercel — use Neon, Supabase, or any Postgres host):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Business Logic Defaults
DEFAULT_EXCHANGE_RATE=35.5
DEFAULT_SERVICE_FEE_PERCENT=1.5
DEFAULT_NETWORK_FEE_TRC20=1.0
DEFAULT_NETWORK_FEE_ERC20=15.0
DEFAULT_NETWORK_FEE_BEP20=0.8

# Bitkub API
BITKUB_API_KEY=""
BITKUB_API_SECRET=""
BITKUB_API_BASE_URL="https://api.bitkub.com"
BITKUB_SYMBOL="THB_USDT"
BITKUB_AUTO_RATE_SYNC="false"

# Storage
# On Vercel, only /tmp is writable — uploaded files are ephemeral per-invocation.
# For production file persistence, integrate a cloud storage service (S3, Cloudinary, etc.)
UPLOAD_DIR="./uploads"

# Email Config
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="PromptPay USDT <noreply@example.com>"
